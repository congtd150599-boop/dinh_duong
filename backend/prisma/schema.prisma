generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // raw inputs
  name      String
  dob       DateTime
  examDate  DateTime
  gender    String // 'Nam' | 'Nữ' — validated via zod at the API boundary, not a Postgres enum
  weight    Float
  height    Float
  muac      Float?
  revisit   DateTime?
  tuvan     String // 'Có' | 'Không'
  revisitReminderSentAt  DateTime? // set once the reminder email succeeds, so the daily scan never double-sends

  // Links this visit to the child's persistent record (see Child) so multiple
  // visits for the same kid can be grouped for trend charts/growth alerts.
  // name/dob/gender above stay as an immutable per-visit snapshot — they are
  // NOT re-derived from Child, so a later correction to Child's name/dob does
  // not rewrite history (see plan notes on this being accepted, documented debt).
  childId String
  child   Child  @relation(fields: [childId], references: [id])

  // Which staff account recorded this visit — attribution/filtering only
  // ("Khám bởi", "Danh sách của tôi"), NEVER a visibility restriction: every
  // visit stays readable by every staff account regardless of who examined
  // it, because a doctor picking up a follow-up visit must see the full
  // history a *different* doctor recorded to avoid missing prior alerts/
  // allergies (this is why Child groups every visit in the first place — see
  // Child's doc comment). Nullable because visits recorded before this field
  // existed have no known examiner, and a real FK (not a snapshot like
  // AuditLog.userId) is safe here since User rows are only ever
  // deactivated (status), never hard-deleted — see User's doc comment.
  examinedByUserId String?
  examinedBy       User?   @relation(fields: [examinedByUserId], references: [id])

  reportEmailLogs ReportEmailLog[]

  // raw optional lab inputs
  labCa        Float?
  labVitD      Float?
  labZn        Float?
  labHb        Float?
  labFe        Float?
  labFerritin  Float?
  labChol      Float?
  labTg        Float?

  // denormalized computed summary (fast list/CSV rendering without recompute)
  months               Int
  bmi                  Float
  wfa                  String
  hfa                  String
  wfh                  String
  muacStatus           String?
  stdEnergy            Int
  targetEnergy         Int
  carbG                Int
  proteinG             Int
  lipidG               Int
  labAssessmentSummary String // comma-joined non-ok diagnoses, default 'Bình thường'

  // full computed result frozen at save time (audit/history — see plan notes)
  fullResult Json

  @@index([examDate])
  @@index([name])
  @@index([childId])
}

// A child's persistent identity, spanning every visit they've ever had (see
// Patient.childId). Looked up/selected by the doctor in the input form (or
// auto-created via child.service.ts's findOrCreateChild when no existing
// record was picked) — this is what lets the app group visits for trend
// charts and growth-faltering alerts instead of just guessing by name+dob.
model Child {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  name      String
  dob       DateTime
  gender    String // 'Nam' | 'Nữ'
  patients  Patient[]
  guardians Guardian[]
  reportEmailLogs ReportEmailLog[]

  @@index([name])
}

// Bố/Mẹ (or in principle any future relationship) of a Child — kept here, not
// per-visit on Patient, so contact info always reflects the latest value
// regardless of which visit last updated it (a doctor forgetting to re-type
// it on a follow-up visit no longer breaks scanAndSendRevisitReminders()).
// All fields nullable at the DB level — the real "at least one guardian has
// both email and phone" rule is enforced in guardian.service.ts/patient.service.ts,
// not here (Postgres can't cleanly check "at least one of N related rows").
model Guardian {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  childId      String
  child        Child     @relation(fields: [childId], references: [id])
  relationship String // 'Bố' | 'Mẹ' — validated via zod at the API boundary, not a Postgres enum
  name         String?
  dob          DateTime?
  address      String?
  email        String?
  phone        String?

  @@unique([childId, relationship])
}

// One row per email-send attempt for a patient's PDF report (see
// report.service.ts's sendPatientReportEmail) — lets staff answer "did we
// already send this family a report, and did it succeed?" (previously
// send-and-forget, no record kept). recipientEmail/recipientName are
// snapshotted at send time rather than read live off Guardian, since the
// guardian's contact info can change afterward and the log should reflect
// who it actually went to. guardianId is NOT a relation (no FK) — a
// guardian row can later be edited or removed without needing to touch
// historical log rows.
model ReportEmailLog {
  id             String   @id @default(cuid())
  sentAt         DateTime @default(now())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id])
  childId        String
  child          Child    @relation(fields: [childId], references: [id])
  guardianId     String?
  recipientEmail String
  recipientName  String?
  status         String // 'sent' | 'failed' — validated in code, not a Postgres enum (same convention as other string-enum fields in this schema)
  errorMessage   String?

  @@index([childId])
  @@index([patientId])
}

// Staff accounts for login + role-based access control. Self-registration
// (POST /api/auth/register) creates a row here with status='pending' and
// role='dieu_duong' (lowest privilege, never admin) — requireAuth refuses to
// log a pending account in, same as a 'disabled' one, until an admin reviews
// it via PATCH /api/users/:id and flips status to 'active' (optionally
// changing role first). This replaces the old plain isActive boolean so
// "awaiting approval" and "explicitly deactivated by an admin" are two
// distinct, unambiguous states instead of both just meaning isActive=false.
model User {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  name         String
  email        String   @unique
  passwordHash String
  role         String // 'admin' | 'bac_si' | 'dieu_duong' — validated via zod at the API boundary, not a Postgres enum
  status       String   @default("active") // 'pending' | 'active' | 'disabled' — validated via zod at the API boundary, not a Postgres enum

  examinedPatients Patient[]
}

// Growth-reference median lookup (WFA/HFA), separated from code so it can be
// re-imported later (e.g. when WHO revises a standard) without a deploy.
// A bundled CSV default (backend/src/data/growth-standards-who-default.csv)
// seeds this table on first run; importing a new CSV replaces it.
model GrowthStandardPoint {
  id       String   @id @default(cuid())
  gender   String // 'Nam' | 'Nữ'
  metric   String // 'WFA' | 'HFA'
  months   Int
  median   Float // the LMS "M" parameter
  l        Float? // LMS "L" (skewness) parameter — real WHO LMS Z-score method, not the old flat-coefficient approximation
  s        Float? // LMS "S" (coefficient of variation) parameter
  source   String // free-text citation, e.g. "WHO Child Growth Standards 2006"
  importedAt DateTime @default(now())

  @@unique([gender, metric, months])
}

// Lab test reference-range lookup (Calci, Vitamin D, Kẽm, Hb, Sắt, Ferritin,
// Cholesterol, Triglycerid), separated from code so a threshold can be tuned
// per real lab-machine calibration or updated guidance without a deploy —
// same rationale as GrowthStandardPoint. A bundled default (matching the
// values previously hardcoded in lab-assessment.service.ts) seeds this table
// on first run; importing a CSV replaces it wholesale. See Bugs.md for the
// incident that prompted this (a real lab slip showed Sắt huyết thanh has a
// gender-specific range and Cholesterol/Triglycerid are reported in mmol/L,
// not the mg/dL the app previously assumed).
model LabReferenceRange {
  id     String @id @default(cuid())
  testKey String // 'ca' | 'vitD' | 'zn' | 'hb' | 'fe' | 'ferritin' | 'chol' | 'tg'
  gender String // 'Nam' | 'Nữ' | 'Cả hai' — 'Cả hai' matches a patient of either gender
  minMonths Int // inclusive
  maxMonths Int // inclusive
  // All 4 nullable — which ones are set depends on the test's shape: a
  // one-sided lower-bound test (Kẽm) only sets lowDeficit; a two-tier test
  // (Vitamin D) sets lowSevere+lowDeficit; a two-sided test (Calci, Sắt) sets
  // lowDeficit+highExcess; a two-tier upper test (Cholesterol) sets
  // highBorderline+highExcess.
  lowSevere      Float?
  lowDeficit     Float?
  highBorderline Float?
  highExcess     Float?
  // Whether the high-side comparisons use >= (Cholesterol/Triglycerid, per
  // their original hardcoded logic) instead of the default > (Calci/Sắt).
  highInclusive Boolean @default(false)
  unit          String
  source        String
  importedAt    DateTime @default(now())

  @@unique([testKey, gender, minMonths, maxMonths])
}

// Doctor-editable food reference list: nutrition figures, benefits, and
// disease-contraindication tags. Also the live candidate pool for
// menu-optimizer.service.ts's weekly-menu generation (see that file) —
// costPer100/preferenceScore feed its 3-way nutrition/cost/preference
// scoring. A subset of rows (isSystemDefault) is bundled as bootstrap data
// (food-composition.data.ts) so the optimizer always has enough candidates
// per food group even on a fresh install — those rows can be edited but not
// deleted through the UI/API.
model Food {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  name            String   @unique
  category        String // one of FOOD_CATEGORIES (@dinhduong/shared) — validated via zod at the API boundary
  kcalPer100      Float
  proteinPer100   Float    @default(0)
  carbPer100      Float    @default(0)
  fatPer100       Float    @default(0)
  // VNĐ per 100g/100ml — nullable because most staff won't have real prices
  // on day one. Null is treated as "unknown", never as "free": the optimizer
  // gives it a neutral mid-score rather than penalizing or favoring it, so
  // cost only actually influences ranking once real prices are entered.
  costPer100      Float?
  // 1 (rarely eaten/liked) – 5 (very popular) — a doctor's own judgment of
  // how well local families take to this food, one of the 3 equally-weighted
  // scoring axes in menu-optimizer.service.ts. Defaults to 3 (neutral) so an
  // unrated food is never penalized relative to a rated-average one.
  preferenceScore Int      @default(3)
  benefits        String?
  cautionNote     String?
  conditionTags   String[] // subset of FOOD_CONDITION_TAGS (@dinhduong/shared)
  source          String?
  isSystemDefault Boolean  @default(false)
}

// One row per mutating action taken by a logged-in staff member (create/
// update/delete across Patient/Guardian/User/Food/GrowthStandardPoint) —
// accountability trail for "who changed what, when". userId is NOT a
// relation (no FK) — deleting a User must never be blocked by, or cascade
// into, their historical audit rows; userName/userEmail are snapshotted at
// write time so entries stay meaningful even if the account is later
// renamed or removed. Written best-effort (see audit-log.service.ts) —
// a logging failure must never block the real mutation it's describing.
model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String?
  userName   String
  userEmail  String
  action     String // e.g. 'patient.create', 'user.reset_password' — free-form dot-namespaced, not a Postgres enum (same convention as other string-enum fields in this schema)
  targetType String // 'Patient' | 'Guardian' | 'User' | 'Food' | 'GrowthStandardPoint' | 'LabReferenceRange'
  targetId   String?
  summary    String // human-readable one-liner shown in the audit log UI, e.g. 'Xoá bệnh nhân "Nguyễn Văn A"'

  @@index([createdAt])
  @@index([userId])
}
