generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // raw inputs
  name      String
  dob       DateTime
  examDate  DateTime
  gender    String // 'Nam' | 'Nữ' — validated via zod at the API boundary, not a Postgres enum
  weight    Float
  height    Float
  muac      Float?
  revisit   DateTime?
  tuvan     String // 'Có' | 'Không'
  revisitReminderSentAt  DateTime? // set once the reminder email succeeds, so the daily scan never double-sends

  // Links this visit to the child's persistent record (see Child) so multiple
  // visits for the same kid can be grouped for trend charts/growth alerts.
  // name/dob/gender above stay as an immutable per-visit snapshot — they are
  // NOT re-derived from Child, so a later correction to Child's name/dob does
  // not rewrite history (see plan notes on this being accepted, documented debt).
  childId String
  child   Child  @relation(fields: [childId], references: [id])

  // raw optional lab inputs
  labCa        Float?
  labVitD      Float?
  labZn        Float?
  labHb        Float?
  labFe        Float?
  labFerritin  Float?
  labChol      Float?
  labTg        Float?

  // denormalized computed summary (fast list/CSV rendering without recompute)
  months               Int
  bmi                  Float
  wfa                  String
  hfa                  String
  wfh                  String
  muacStatus           String?
  stdEnergy            Int
  targetEnergy         Int
  carbG                Int
  proteinG             Int
  lipidG               Int
  labAssessmentSummary String // comma-joined non-ok diagnoses, default 'Bình thường'

  // full computed result frozen at save time (audit/history — see plan notes)
  fullResult Json

  @@index([examDate])
  @@index([name])
  @@index([childId])
}

// A child's persistent identity, spanning every visit they've ever had (see
// Patient.childId). Looked up/selected by the doctor in the input form (or
// auto-created via child.service.ts's findOrCreateChild when no existing
// record was picked) — this is what lets the app group visits for trend
// charts and growth-faltering alerts instead of just guessing by name+dob.
model Child {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  name      String
  dob       DateTime
  gender    String // 'Nam' | 'Nữ'
  patients  Patient[]
  guardians Guardian[]

  @@index([name])
}

// Bố/Mẹ (or in principle any future relationship) of a Child — kept here, not
// per-visit on Patient, so contact info always reflects the latest value
// regardless of which visit last updated it (a doctor forgetting to re-type
// it on a follow-up visit no longer breaks scanAndSendRevisitReminders()).
// All fields nullable at the DB level — the real "at least one guardian has
// both email and phone" rule is enforced in guardian.service.ts/patient.service.ts,
// not here (Postgres can't cleanly check "at least one of N related rows").
model Guardian {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  childId      String
  child        Child     @relation(fields: [childId], references: [id])
  relationship String // 'Bố' | 'Mẹ' — validated via zod at the API boundary, not a Postgres enum
  name         String?
  dob          DateTime?
  address      String?
  email        String?
  phone        String?

  @@unique([childId, relationship])
}

// Staff accounts for login + role-based access control.
model User {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  name         String
  email        String   @unique
  passwordHash String
  role         String // 'admin' | 'bac_si' | 'dieu_duong' — validated via zod at the API boundary, not a Postgres enum
  isActive     Boolean  @default(true)
}

// Growth-reference median lookup (WFA/HFA), separated from code so it can be
// re-imported later (e.g. when WHO revises a standard) without a deploy.
// A bundled CSV default (backend/src/data/growth-standards-who-default.csv)
// seeds this table on first run; importing a new CSV replaces it.
model GrowthStandardPoint {
  id       String   @id @default(cuid())
  gender   String // 'Nam' | 'Nữ'
  metric   String // 'WFA' | 'HFA'
  months   Int
  median   Float // the LMS "M" parameter
  l        Float? // LMS "L" (skewness) parameter — real WHO LMS Z-score method, not the old flat-coefficient approximation
  s        Float? // LMS "S" (coefficient of variation) parameter
  source   String // free-text citation, e.g. "WHO Child Growth Standards 2006"
  importedAt DateTime @default(now())

  @@unique([gender, metric, months])
}

// Doctor-editable food reference list: nutrition figures, benefits, and
// disease-contraindication tags. A subset of ~20 rows (isSystemDefault) also
// back menu.service.ts's dish-keyword nutrition lookup (see food.service.ts),
// so editing one changes the generated weekly menu — those rows can be
// edited but not deleted through the UI/API.
model Food {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  name            String   @unique
  category        String // one of FOOD_CATEGORIES (@dinhduong/shared) — validated via zod at the API boundary
  kcalPer100      Float
  proteinPer100   Float    @default(0)
  carbPer100      Float    @default(0)
  fatPer100       Float    @default(0)
  benefits        String?
  cautionNote     String?
  conditionTags   String[] // subset of FOOD_CONDITION_TAGS (@dinhduong/shared)
  source          String?
  isSystemDefault Boolean  @default(false)
}
