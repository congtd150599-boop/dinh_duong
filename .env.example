# Postgres
POSTGRES_USER=dinhduong
POSTGRES_PASSWORD=dinhduong_dev_password
POSTGRES_DB=dinhduong

# Backend (inside Docker network — service name, not localhost)
DATABASE_URL=postgresql://dinhduong:dinhduong_dev_password@postgres:5432/dinhduong?schema=public
DATABASE_URL_TEST=postgresql://dinhduong:dinhduong_dev_password@postgres:5432/dinhduong_test?schema=public
PORT=4000

# Frontend (host-facing — the browser calls this, not a container)
VITE_API_URL=http://localhost:4000/api
