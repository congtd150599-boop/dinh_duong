# Postgres
POSTGRES_USER=dinhduong
POSTGRES_PASSWORD=dinhduong_dev_password
POSTGRES_DB=dinhduong

# Backend (inside Docker network — service name, not localhost)
DATABASE_URL=postgresql://dinhduong:dinhduong_dev_password@postgres:5432/dinhduong?schema=public
DATABASE_URL_TEST=postgresql://dinhduong:dinhduong_dev_password@postgres:5432/dinhduong_test?schema=public
PORT=4000

# Frontend (host-facing — the browser calls this, not a container)
VITE_API_URL=http://localhost:4000/api

# Auth — JWT-in-httpOnly-cookie, no server-side session store (survives
# nodemon's dev restarts). JWT_SECRET has no default — the server refuses to
# start without it, so generate a real random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h
# Only matters in dev (frontend :5173 → backend :4000, cross-origin); prod is
# same-origin via Nginx (see frontend/nginx.conf) so CORS is a no-op there.
CORS_ORIGIN=http://localhost:5173
# First admin account, auto-created once at server startup if the User table
# is empty (see auth.service.ts bootstrapAdminIfNeeded). Leave blank after the
# first run — the table won't be empty anymore, so these are ignored.
ADMIN_NAME=Quản trị viên
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Dùng chung cho nhắc lịch tái khám (quét tự động mỗi ngày, node-cron) và gửi
# báo cáo PDF qua email (nút "Gửi báo cáo" ở tab Kết Quả). Để trống bất kỳ
# biến SMTP_* nào → hệ thống tự chuyển sang "dry-run" (chỉ log ra console
# thay vì gửi thật), nên cả 2 tính năng hoạt động ngay cả khi chưa có tài
# khoản SMTP thật; điền vào sau không cần đổi code hay build lại.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
# Không dùng dấu ngoặc kép — env_file đọc nguyên văn, không phải shell.
# VD: SMTP_FROM=Phong Kham Dinh Duong <no-reply@example.com>
SMTP_FROM=
# Số ngày trước lịch tái khám thì bắt đầu gửi nhắc.
REVISIT_REMINDER_DAYS_BEFORE=3
# Lịch quét (cron expression), mặc định 8:00 sáng mỗi ngày.
REVISIT_REMINDER_CRON=0 8 * * *

# Sao lưu dữ liệu định kỳ (pg_dump, xem backup.service.ts) — lịch mặc định
# 2:00 sáng mỗi ngày, giữ lại 14 bản gần nhất, các bản cũ hơn tự động xoá.
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=14
# Để trống → dùng thư mục mặc định backend/backups (đã map sẵn volume riêng
# trong docker-compose.prod.yml, tách khỏi volume của chính DB đang chạy).
BACKUP_DIR=
